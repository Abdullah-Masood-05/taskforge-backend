# ─── Core Django ──────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://taskforge:taskforge@localhost:5432/taskforge

# ─── Cache ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# ─── Google OAuth2 (django-allauth) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email ────────────────────────────────────────────────────────────────────
# Dev: console backend is used automatically. Set this for email link generation.
DEFAULT_FROM_EMAIL=noreply@taskforge.io

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Used for CORS and email verification links pointing at the frontend.
# Next.js dev server runs on 3000 by default.
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Coming in later phases ───────────────────────────────────────────────────
# Phase 3: SENDGRID_API_KEY, AWS_*, CELERY_*
# Phase 4: STRIPE_*
# Phase 6: SENTRY_DSN
