# ─── Core Django ──────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://taskforge:taskforge@localhost:5432/taskforge

# ─── Cache ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# ─── Google OAuth2 (django-allauth) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email ────────────────────────────────────────────────────────────────────
# Dev: console backend is used automatically. Set this for email link generation.
DEFAULT_FROM_EMAIL=noreply@taskforge.io

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Used for CORS and email verification links pointing at the frontend.
# Next.js dev server runs on 3000 by default.
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Stripe (Phase 4) ─────────────────────────────────────────────────────────
# Use Stripe test keys (sk_test_...) for dev/CI. Never commit live keys.
# Get test keys: https://dashboard.stripe.com/test/apikeys
# Get webhook secret by running: stripe listen --forward-to localhost:8000/api/v1/billing/webhook/
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_pro_plan_id_here
STRIPE_BUSINESS_PRICE_ID=price_business_plan_id_here

# ─── Coming in later phases ───────────────────────────────────────────────────
# Phase 6: SENTRY_DSN
